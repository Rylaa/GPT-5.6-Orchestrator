{
  "name": "gpt-5-6-orchestrator",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "description": "GPT-5.6 Sol main-session orchestration with dynamic pinned Codex subagents and configurable Sol reasoning.",
  "scripts": {
    "check": "npm run check:syntax && npm run test:coverage && npm run test:coverage:critical",
    "check:compat": "npm run check:syntax && npm test",
    "check:syntax": "node scripts/check-syntax.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include='lib/*.mjs' --test-coverage-include='hooks/*.mjs' --test-coverage-include='scripts/*.mjs' --test-coverage-exclude='tests/**' --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=80 tests/*.test.mjs",
    "test:coverage:critical": "npm run test:coverage:proof && npm run test:coverage:controller && npm run test:coverage:hooks",
    "test:coverage:controller": "node --test --experimental-test-coverage --test-coverage-include='scripts/orchestrator.mjs' --test-coverage-lines=85 --test-coverage-functions=80 --test-coverage-branches=75 tests/*.test.mjs",
    "test:coverage:hooks": "node --test --experimental-test-coverage --test-coverage-include='lib/hook-handler.mjs' --test-coverage-lines=85 --test-coverage-functions=80 --test-coverage-branches=80 tests/*.test.mjs",
    "test:coverage:proof": "node --test --experimental-test-coverage --test-coverage-include='lib/proof.mjs' --test-coverage-lines=85 --test-coverage-functions=80 --test-coverage-branches=80 tests/*.test.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
