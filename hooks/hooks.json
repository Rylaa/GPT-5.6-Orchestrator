{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" session-start",
            "timeout": 10,
            "statusMessage": "Loading GPT-5.6 orchestration policy"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" post-compact",
            "timeout": 10,
            "statusMessage": "Restoring GPT-5.6 orchestration policy"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" user-prompt-submit",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(?:apply_patch|spawn_agent|.*(?:__|\\.)spawn_agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" pre-tool-use",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" subagent-start",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" subagent-stop",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/hooks/orchestrator-hook.mjs\" stop",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
